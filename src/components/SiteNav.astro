---
const links = [
	{ href: '/', label: 'home' },
	{ href: '/projects/', label: 'projects' },
	{ href: '/notes/', label: 'notes' }
];

const pathname = Astro.url.pathname;
const isActive = (href) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<nav class="flex items-center gap-5 text-sm">
	{links.map((link) => (
		<a
			href={link.href}
			class={
				link.href === '/'
					? 'hover:underline'
					: isActive(link.href)
						? 'underline'
						: 'hover:underline'
			}
		>
			{link.label}
		</a>
	))}
</nav>
