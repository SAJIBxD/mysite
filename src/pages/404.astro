---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lost cat" description="Page not found" mainClass="not-found-page">
	<header class="page-header">
		<p class="page-eyebrow">404</p>
		<h1 class="page-title">
			This cat ate<br /><em>your page.</em>
		</h1>
		<p class="page-subtitle">
			We checked under the couch, behind the curtains, and inside a cardboard box. Still nothing.
		</p>
	</header>

	<section class="bio">
		<div class="mascot-wrap">
			<img src="/cat_lost.png" alt="Lost cat illustration" />
		</div>
		<div class="bio-text">
			<p>The page you are looking for is gone, renamed, or never existed.</p>
			<p>
				<a href="/">Return home</a> or browse <a href="/notes/">notes</a> and <a href="/projects/">projects</a>.
			</p>
		</div>
	</section>
</Layout>
