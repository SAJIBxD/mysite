---
import Layout from '../layouts/Layout.astro';
---

<Layout title="lost cat" description="Page not found" mainClass="flex-1 grid gap-12 md:grid-cols-[45%_55%] items-center">
	<div class="flex justify-center">
		<img src="/cat_lost.png" alt="Lost cat illustration" class="max-w-[330px] w-full h-auto dark-invert" />
	</div>

	<div>
		<h1 class="text-3xl mb-4">404: this cat ate your page</h1>
		<p class="text-[#666] mb-8">We checked under the couch, behind the curtains, and inside a cardboard box. Still nothing.</p>

		<p class="mt-12">
			<a href="/" class="hover:underline">← take me home</a>
		</p>
	</div>
</Layout>
