---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - Sajib" description="About Sajib." mainClass="about-page">
	<header class="page-header page-header--about">
		<div class="header-text">
			<p class="page-eyebrow">The person</p>
			<h1 class="page-title">
				Hey, I'm<br /><em>Sajib.</em>
			</h1>
		</div>
		<div class="about-mascot">
			<img src="/cat_with_glasses.png" alt="Cat with glasses - Sajib's mascot" />
		</div>
	</header>

	<section class="bio-section">
		<p class="section-label">A bit about me</p>
		<div class="bio-body">
			<p>
				I make things for the web. Nothing too fancy - just stuff that works and looks decent.
				I'd rather take my time than rush something half-baked out the door.
			</p>
			<p>
				Most of what I build is small: experiments, random tools, the occasional side project
				that actually goes somewhere. I write stuff down when I learn something useful, and
				I share code when I think it might help someone.
			</p>
			<p>
				This site is just my corner of the web. No algorithm, no feed, no pressure. Just
				whatever I'm working on or thinking about.
			</p>
		</div>
	</section>

	<section class="now-section">
		<p class="section-label">Currently</p>
		<div class="now-grid">
			<div class="now-cell">
				<span class="now-cell-label">Working on</span>
				<ul>
					<li>
						This website<span>Making it better, slowly</span>
					</li>
					<li>
						Small side projects<span>Tools that solve my own problems first</span>
					</li>
					<li>
						Learning in public<span>Notes, experiments, and writeups</span>
					</li>
				</ul>
			</div>
			<div class="now-cell">
				<span class="now-cell-label">Interested in</span>
				<ul>
					<li>
						The web<span>HTML, CSS, JavaScript, performance</span>
					</li>
					<li>
						Design<span>Typography, layout systems, visual rhythm</span>
					</li>
					<li>
						Open source<span>Small tools and useful workflows</span>
					</li>
				</ul>
			</div>
			<div class="now-cell">
				<span class="now-cell-label">Learning</span>
				<ul class="learning-list">
					<li>
						<span class="learning-label">AI / ML</span>
						<div class="progress-bar"><div class="progress-fill" style="width:70%"></div></div>
						<span class="learning-pct">70%</span>
					</li>
					<li>
						<span class="learning-label">Web designing</span>
						<div class="progress-bar"><div class="progress-fill" style="width:90%"></div></div>
						<span class="learning-pct">90%</span>
					</li>
					<li>
						<span class="learning-label">Android development</span>
						<div class="progress-bar"><div class="progress-fill" style="width:12%"></div></div>
						<span class="learning-pct">12%</span>
					</li>
				</ul>
			</div>
		</div>
	</section>

	<section class="stack-section">
		<p class="section-label">Tech stack</p>
		<div class="stack-badges">
			<span class="badge">HTML</span>
			<span class="badge">CSS</span>
			<span class="badge">JavaScript</span>
			<span class="badge">TypeScript</span>
			<span class="badge">React</span>
			<span class="badge">Astro</span>
			<span class="badge">Node.js</span>
			<span class="badge">Python</span>
			<span class="badge">C</span>
			<span class="badge">C++</span>
			<span class="badge">Git</span>
			<span class="badge">Zsh</span>
			<span class="badge">MongoDB</span>
			<span class="badge">Express</span>
			<span class="badge">Vite</span>
			<span class="badge">FastAPI</span>
			<span class="badge">Scikit-learn</span>
			<span class="badge">Pandas</span>
			<span class="badge">Pug</span>
			<span class="badge">Socket.io</span>
		</div>
	</section>

	<section class="contact-section">
		<p class="section-label">Find me</p>
		<div class="contact-list">
			<a href="https://github.com/SAJIBxD" target="_blank" rel="noopener" class="contact-item">
				<span class="contact-platform">GitHub</span>
				<span class="contact-handle">SAJIBxD</span>
				<span class="contact-arrow">↗</span>
			</a>
			<a href="mailto:sajibxd@proton.me" class="contact-item">
				<span class="contact-platform">Email</span>
				<span class="contact-handle">sajibxd@proton.me</span>
				<span class="contact-arrow">↗</span>
			</a>
		</div>
	</section>
</Layout>
