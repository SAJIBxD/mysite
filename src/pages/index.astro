---
import Layout from '../layouts/Layout.astro';

const homeLinks = [
	{
		href: '/projects/',
		title: 'Projects',
		description: "Things I've built and shipped.",
		external: false
	},
	{
		href: '/notes/',
		title: 'Notes',
		description: 'Thoughts, learnings, fragments.',
		external: false
	},
	{
		href: '/about/',
		title: 'About',
		description: 'Who I am and what I care about.',
		external: false
	},
	{
		href: 'https://github.com/SAJIBxD',
		title: 'GitHub',
		description: 'Open source work and experiments.',
		external: true
	}
];
---

<Layout title="Sajib — Exploring & Building on the Web" description="Personal website of Sajib." mainClass="home">
	<section class="hero">
		<p class="hero-eyebrow">Personal site</p>
		<h1 class="hero-name">
			Slowly<br /><em>building</em><br />the web.
		</h1>
		<p class="hero-tagline">A small place on the web where I build things and share what I learn.</p>
	</section>

	<section class="links-section">
		<p class="section-label">Explore</p>
		<div class="link-grid">
			{homeLinks.map((link, index) => (
				<a href={link.href} class="link-card" target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined}>
					<span class="link-card-num">{String(index + 1).padStart(2, '0')}</span>
					<div class="link-card-title">
						{link.title} <span class="arrow">{link.external ? '↗' : '→'}</span>
					</div>
					<p class="link-card-desc">{link.description}</p>
				</a>
			))}
		</div>
	</section>
</Layout>
