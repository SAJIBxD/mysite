---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Home" mainClass="flex-1 grid gap-10 md:grid-cols-[40%_60%] items-start">
	<aside class="flex justify-center">
		<img
			src="/cat_with_glasses.png"
			alt="Cat sketch with glasses"
			class="max-w-[320px] w-full h-auto"
		/>
	</aside>

	<section class="max-w-[460px]">
		<p class="text-xl md:text-[1.35rem]">
			Exploring and building on the web, slowly.
		</p>

		<div class="mt-12 space-y-5 text-base">
			<a href="/projects/" class="block text-center">
				projects <span class="text-[#3b5bdb] pl-1">→</span>
			</a>
			<a href="/notes/" class="block text-center">
				notes <span class="text-[#3b5bdb] pl-1">→</span>
			</a>
			<a href="https://github.com/SAJIBxD" target="_blank" class="block text-center">
				github <span class="text-[#3b5bdb] pl-1">→</span>
			</a>
			<a href="/about/" class="block text-center">
				about <span class="text-[#3b5bdb] pl-1">→</span>
			</a>
		</div>
	</section>
</Layout>
