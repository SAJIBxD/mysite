---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const formattedDate = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric'
}).format(entry.data.pubDate);
---

<Layout
	title={entry.data.title}
	description={entry.data.description ?? entry.data.title}
	mainClass="note-detail"
>
	<header class="page-header">
		<p class="page-eyebrow">Note</p>
		<h1 class="page-title">{entry.data.title}</h1>
		<p class="page-subtitle">{entry.data.description ?? 'A note from my personal archive.'}</p>
		<p class="page-subtitle page-subtitle--mono">{formattedDate}</p>
	</header>

	<article class="prose">
		<Content />
	</article>

	<p class="back-link">
		<a href="/notes/">← Back to notes</a>
	</p>
</Layout>
