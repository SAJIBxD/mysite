---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const formatDate = (date: Date) => {
	const month = new Intl.DateTimeFormat('en-US', { month: 'short' }).format(date);
	const year = new Intl.DateTimeFormat('en-US', { year: 'numeric' }).format(date);
	return { month, year };
};

const notes = (await getCollection('notes'))
	.map((note) => ({
		...note,
		date: note.data.pubDate
	}))
	.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Layout title="Notes - Sajib" description="Notes, learnings, and thoughts." mainClass="notes-page">
	<header class="page-header">
		<p class="page-eyebrow">Writing</p>
		<h1 class="page-title">
			Notes &<br /><em>thoughts.</em>
		</h1>
		<p class="page-subtitle">
			Fragments, learnings, and things I wanted to write down. No particular schedule - just when
			something feels worth sharing.
		</p>
	</header>

	<section class="notes-section">
		<p class="section-label">All notes</p>
		<div class="note-list">
			{notes.map((note) => {
				const displayDate = formatDate(note.date);
				return (
					<a href={`/notes/${note.slug}/`} class="note-card">
						<span class="note-date">
							{displayDate.month}<br />{displayDate.year}
						</span>
						<div class="note-body">
							<h2 class="note-title">{note.data.title}</h2>
							<p class="note-snippet">{note.data.summary ?? note.data.description ?? 'No summary provided yet.'}</p>
						</div>
						<span class="note-arrow">→</span>
					</a>
				);
			})}
		</div>
	</section>
</Layout>
