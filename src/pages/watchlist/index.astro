---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type WatchlistEntry = CollectionEntry<'watchlist'>;
type WatchlistItem = WatchlistEntry['data']['items'][number];
type PlannedItem = NonNullable<WatchlistEntry['data']['planned']>[number];

const entries = await getCollection('watchlist');
const sortedEntries = [...entries].sort((a, b) => b.data.year - a.data.year);
const years = sortedEntries.map((entry) => entry.data.year);
const activeYear = years[0];
const activeEntry = sortedEntries.find((entry) => entry.data.year === activeYear);
const items: WatchlistItem[] = activeEntry?.data.items ?? [];
const planned: PlannedItem[] = activeEntry?.data.planned ?? [];

const allItems = sortedEntries.flatMap((entry) => entry.data.items);

const isMovieType = (type: WatchlistItem['type'] | PlannedItem['type']) => type === 'Movie';

const totalMovies = allItems.filter((item) => isMovieType(item.type)).length;
const totalShows = allItems.length - totalMovies;
const totalPlanned = sortedEntries.reduce((sum, entry) => sum + (entry.data.planned?.length ?? 0), 0);

const starString = (rating: number | null | undefined) => {
	if (!rating && rating !== 0) return '';
	const full = Math.floor(rating);
	const half = rating % 1 >= 0.5;
	const empty = 5 - full - (half ? 1 : 0);
	return `${'★'.repeat(full)}${half ? '½' : ''}${'☆'.repeat(empty)}`;
};

const sortedItems = [...items].sort((a, b) => b.watchedDate.getTime() - a.watchedDate.getTime());
const activePlanned = [...planned];

const currentYearRows = [
	...sortedItems.map((item) => ({
		kind: 'watched' as const,
		item,
		labelType: isMovieType(item.type) ? 'Film' : 'TV',
		subline: `${item.year ?? activeYear} · ${item.type}`,
		ratingLabel:
			item.rating || item.rating === 0
				? starString(item.rating)
				: item.status === 'Watching'
					? 'Watching'
					: item.status,
		dotClass: item.status === 'Finished' ? 'done' : item.status === 'Watching' ? 'watching' : ''
	})),
	...activePlanned.map((item) => ({
		kind: 'planned' as const,
		item,
		labelType: isMovieType(item.type) ? 'Film' : 'TV',
		subline: `${item.year ?? activeYear} · Planned`,
		ratingLabel: 'To watch',
		dotClass: ''
	}))
];

const yearStats = sortedEntries.map((entry) => {
	const yearItems = entry.data.items;
	const movies = yearItems.filter((item) => isMovieType(item.type)).length;
	const shows = yearItems.length - movies;
	const watching = yearItems.filter((item) => item.status === 'Watching').length;
	const plannedCount = entry.data.planned?.length ?? 0;
	const inProgress = watching;
	const allFinished = yearItems.length > 0 && yearItems.every((item) => item.status === 'Finished');

	return {
		year: entry.data.year,
		movies,
		shows,
		plannedCount,
		inProgress,
		allFinished
	};
});
---

<Layout title="Watchlist - Sajib" description="Movies and TV shows logged by year." mainClass="watchlist-page">
	<header class="page-header">
		<p class="page-eyebrow">Watching log</p>
		<h1 class="page-title">
			What I've<br /><em>watched.</em>
		</h1>
		<p class="page-subtitle">
			Movies and TV shows I've seen, am watching, or plan to watch - logged by year.
		</p>
	</header>

	<section class="stats-section">
		<p class="section-label">All time</p>
		<div class="stats-grid">
			<div class="stat-cell">
				<span class="stat-num"><em>{totalMovies}</em></span>
				<span class="stat-label">Movies</span>
			</div>
			<div class="stat-cell">
				<span class="stat-num"><em>{totalShows}</em></span>
				<span class="stat-label">TV Shows</span>
			</div>
			<div class="stat-cell">
				<span class="stat-num">{years.length}</span>
				<span class="stat-label">Years logged</span>
			</div>
			<div class="stat-cell">
				<span class="stat-num"><em>{totalPlanned}</em></span>
				<span class="stat-label">Up next</span>
			</div>
		</div>
	</section>

	<section class="current-section">
		<p class="section-label">{activeYear} - in progress</p>
		{currentYearRows.length ? (
			<div class="watch-list">
				{currentYearRows.map((row) => (
					<div class="watch-row">
						<span class={`watch-dot ${row.dotClass}`}></span>
						<div class="watch-body">
							<p class="watch-title">{row.item.title}</p>
							<div class="watch-meta">
								<span class={`watch-type ${row.labelType === 'TV' ? 'tv' : ''}`}>{row.labelType}</span>
								<span class="watch-sub">{row.subline}</span>
							</div>
						</div>
						<span class="watch-rating">{row.ratingLabel || '—'}</span>
					</div>
				))}
			</div>
		) : (
			<p class="page-subtitle">No titles logged yet for this year.</p>
		)}
	</section>

	<section class="years-section">
		<p class="section-label">Browse by year</p>
		<div class="year-index">
			{yearStats.map((entry) => (
				<a href={`/watchlist/${entry.year}/`} class="year-row">
					<span class="year-num">{entry.year}</span>
					<div class="year-counts">
						<span class="year-count-line">
							<span>{entry.movies}</span> movies · <span>{entry.shows}</span> shows
						</span>
						<span class="year-count-line">
							{entry.inProgress || entry.plannedCount
								? `${entry.inProgress} in progress · ${entry.plannedCount} planned`
								: entry.allFinished
									? 'All finished'
									: 'No entries'}
						</span>
					</div>
					<span class="year-arrow">→</span>
				</a>
			))}
		</div>
	</section>
</Layout>
