---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type WatchlistEntry = CollectionEntry<'watchlist'>;
type WatchlistItem = WatchlistEntry['data']['items'][number];
type PlannedItem = NonNullable<WatchlistEntry['data']['planned']>[number];

const entries = await getCollection('watchlist');
const years = entries.map((entry) => entry.data.year).sort((a, b) => b - a);
const activeYear = years[0];
const activeEntry = entries.find((entry) => entry.data.year === activeYear);
const items: WatchlistItem[] = activeEntry?.data.items ?? [];
const planned: PlannedItem[] = activeEntry?.data.planned ?? [];

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(date);

const sortedItems = [...items].sort((a, b) => b.watchedDate.getTime() - a.watchedDate.getTime());
const statusOrder = ['Watching', 'Finished', 'On Hold', 'Dropped'] as const;
type WatchStatus = (typeof statusOrder)[number];
const groupedByStatus = statusOrder.reduce<Record<WatchStatus, WatchlistItem[]>>((acc, status) => {
	acc[status] = sortedItems.filter((item) => item.status === status);
	return acc;
}, {} as Record<WatchStatus, WatchlistItem[]>);
const totals = {
	all: sortedItems.length,
	watching: groupedByStatus.Watching.length,
	finished: groupedByStatus.Finished.length,
	onHold: groupedByStatus['On Hold'].length,
	dropped: groupedByStatus.Dropped.length
};

const starString = (rating: number | null | undefined) => {
	if (!rating && rating !== 0) return '';
	const full = Math.floor(rating);
	const half = rating % 1 >= 0.5;
	const empty = 5 - full - (half ? 1 : 0);
	return `${'★'.repeat(full)}${half ? '½' : ''}${'☆'.repeat(empty)}`;
};
---

<Layout title="Watchlist" description="Watchlist by year." mainClass="flex-1 max-w-3xl mx-auto w-full">
	<h1 class="text-3xl mb-10">watchlist</h1>

	<p class="text-[#666] mb-12">
		A collection of movies/tvs i've watched, watching or planning to watch.
	</p>
	<section class="space-y-5">
		<h2 class="text-xl">{activeYear}</h2>
		<div class="flex-1 mb-6 h-px bg-neutral-300 !mt-1"></div>
		<p class="text-[#666] text-sm">
			{totals.all} titles • {totals.watching} watching • {totals.finished} finished • {totals.onHold} on hold {totals.dropped ? `• ${totals.dropped} dropped` : ''}
		</p>

		{statusOrder.map((status) => (
			<div class="mb-10">
				<h3 class="text-sm uppercase tracking-wider text-[#666] mb-5">
					{status} ({groupedByStatus[status].length})
				</h3>

				{groupedByStatus[status].length ? (
					<div class="space-y-4">
						{groupedByStatus[status].map((item) => (
							<article class="js-watchlist-row grid grid-cols-[1fr_auto] gap-2 sm:grid-cols-[90px_1fr_auto] sm:gap-6 border-b pb-4">
								<time class="hidden text-xs text-[#666] sm:col-span-1 sm:block sm:pt-1">
									{formatDate(item.watchedDate)}
								</time>
								<div>
									<p class="font-medium js-watchlist-title" tabindex="0">
										{item.title} {item.year ? `(${item.year})` : ''}
									</p>
									<p class="text-sm text-[#666] mt-1">
										{item.type}
										{item.episodes ? ` • ${item.episodes} EP${item.episodes === 1 ? '' : 's'}` : ''}
										<span class="sm:hidden"> • {formatDate(item.watchedDate)}</span>
									</p>
								</div>
								{item.rating || item.rating === 0 ? (
									<p class="text-xs text-[#666] text-right justify-self-end sm:pt-1">
										{starString(item.rating)}
									</p>
								) : null}
							</article>
						))}
					</div>
				) : (
					<p class="text-[#666] text-sm">
						{status === 'Dropped' ? 'Nothing dropped this year.' : 'No titles here yet.'}
					</p>
				)}
			</div>
		))}
	</section>

	<section class="space-y-5 mt-14">
		<h2 class="text-xl">watch pipeline</h2>
		<div class="flex-1 mb-6 h-px bg-neutral-300 !mt-1"></div>
		<p class="text-[#666] text-sm">{planned.length} planned</p>

		{planned.length ? (
			<div class="space-y-4">
				{planned.map((item) => (
					<article class="grid grid-cols-1 gap-2 sm:grid-cols-[90px_1fr] sm:gap-6 border-b pb-4">
						<span class="text-xs text-[#666] sm:pt-1">{item.type}</span>
						<div>
							<p class="font-medium">{item.title}</p>
						</div>
					</article>
				))}
			</div>
		) : (
			<p class="text-[#666] text-sm">No planned titles yet.</p>
		)}
	</section>

	<section class="space-y-5 mt-14">
		<h2 class="text-xl">archive</h2>
		<div class="flex-1 mb-6 h-px bg-neutral-300 !mt-1"></div>
		<div class="space-y-4">
			{years
				.filter((year) => year !== activeYear)
				.map((year) => (
					<article class="border-b">
						<a href={`/watchlist/${year}/`} class="text-l text-[#666] hover:underline">
							{year}
						</a>
					</article>
				))}
		</div>
	</section>
</Layout>
