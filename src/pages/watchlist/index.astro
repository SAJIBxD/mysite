---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type WatchlistEntry = CollectionEntry<'watchlist'>;
type WatchlistItem = WatchlistEntry['data']['items'][number];
type PlannedItem = NonNullable<WatchlistEntry['data']['planned']>[number];

const entries = await getCollection('watchlist');
const years = entries.map((entry) => entry.data.year).sort((a, b) => b - a);
const activeYear = years[0];
const activeEntry = entries.find((entry) => entry.data.year === activeYear);
const items: WatchlistItem[] = activeEntry?.data.items ?? [];
const planned: PlannedItem[] = activeEntry?.data.planned ?? [];

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(date);

const formatDateForCard = (date: Date) => {
	const month = new Intl.DateTimeFormat('en-US', { month: 'short' }).format(date);
	const year = new Intl.DateTimeFormat('en-US', { year: 'numeric' }).format(date);
	return { month, year };
};

const sortedItems = [...items].sort((a, b) => b.watchedDate.getTime() - a.watchedDate.getTime());
const statusOrder = ['Watching', 'Finished', 'On Hold', 'Dropped'] as const;
type WatchStatus = (typeof statusOrder)[number];
const groupedByStatus = statusOrder.reduce<Record<WatchStatus, WatchlistItem[]>>((acc, status) => {
	acc[status] = sortedItems.filter((item) => item.status === status);
	return acc;
}, {} as Record<WatchStatus, WatchlistItem[]>);
const totals = {
	all: sortedItems.length,
	watching: groupedByStatus.Watching.length,
	finished: groupedByStatus.Finished.length,
	onHold: groupedByStatus['On Hold'].length,
	dropped: groupedByStatus.Dropped.length
};

const starString = (rating: number | null | undefined) => {
	if (!rating && rating !== 0) return '';
	const full = Math.floor(rating);
	const half = rating % 1 >= 0.5;
	const empty = 5 - full - (half ? 1 : 0);
	return `${'★'.repeat(full)}${half ? '½' : ''}${'☆'.repeat(empty)}`;
};
---

<Layout title="Watchlist - Sajib" description="Watchlist by year." mainClass="watchlist-page">
	<header class="page-header">
		<p class="page-eyebrow">Screen diary</p>
		<h1 class="page-title">
			What I've been<br /><em>watching.</em>
		</h1>
		<p class="page-subtitle">
			A collection of movies and shows I've watched, currently watching, or queued for later.
		</p>
		<p class="page-subtitle page-subtitle--mono">
			{totals.all} titles - {totals.watching} watching - {totals.finished} finished - {totals.onHold} on hold{totals.dropped ? ` - ${totals.dropped} dropped` : ''}
		</p>
	</header>

	<section class="notes-section">
		<p class="section-label">{activeYear}</p>
		{statusOrder.map((status) => (
			<div class="watchlist-group">
				<h2 class="watchlist-group-title">
					{status} ({groupedByStatus[status].length})
				</h2>

				{groupedByStatus[status].length ? (
					<div class="note-list">
						{groupedByStatus[status].map((item) => {
							const cardDate = formatDateForCard(item.watchedDate);
							return (
								<article class="note-card js-watchlist-row">
									<span class="note-date">
										{cardDate.month}<br />{cardDate.year}
									</span>
									<div class="note-body watchlist-body">
										<h3 class="note-title js-watchlist-title" tabindex="0">
											{item.title} {item.year ? `(${item.year})` : ''}
										</h3>
										<p class="note-snippet">
											{item.type} - {formatDate(item.watchedDate)}
											{item.episodes ? ` - ${item.episodes} EP${item.episodes === 1 ? '' : 's'}` : ''}
										</p>
									</div>
									<span class="watchlist-rating">{item.rating || item.rating === 0 ? starString(item.rating) : '—'}</span>
								</article>
							);
						})}
					</div>
				) : (
					<p class="page-subtitle">{status === 'Dropped' ? 'Nothing dropped this year.' : 'No titles here yet.'}</p>
				)}
			</div>
		))}
	</section>

	<section class="projects-section watchlist-split-section">
		<p class="section-label">Watch pipeline ({planned.length})</p>
		{planned.length ? (
			<div class="project-list">
				{planned.map((item, index) => (
					<article class="project-card watchlist-plan-card">
						<span class="project-num">{String(index + 1).padStart(2, '0')}</span>
						<div class="project-body">
							<h3 class="project-title">{item.title}</h3>
							<p class="project-desc">{item.type}{item.year ? ` - ${item.year}` : ''}</p>
						</div>
						<span class="project-arrow">→</span>
					</article>
				))}
			</div>
		) : (
			<p class="page-subtitle">No planned titles yet.</p>
		)}
	</section>

	<section class="projects-section watchlist-split-section">
		<p class="section-label">Archive</p>
		<div class="project-list">
			{years
				.filter((year) => year !== activeYear)
				.map((year, index) => (
					<a href={`/watchlist/${year}/`} class="project-card watchlist-archive-card">
						<span class="project-num">{String(index + 1).padStart(2, '0')}</span>
						<div class="project-body">
							<h3 class="project-title">{year}</h3>
							<p class="project-desc">View entries from {year}</p>
						</div>
						<span class="project-arrow">→</span>
					</a>
				))}
		</div>
	</section>
</Layout>
