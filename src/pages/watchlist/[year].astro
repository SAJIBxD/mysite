---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import WatchlistCard from '../../components/WatchlistCard.astro';

type WatchlistEntry = CollectionEntry<'watchlist'>;
type WatchlistItem = WatchlistEntry['data']['items'][number];

export async function getStaticPaths() {
	const entries = await getCollection('watchlist');
	return entries.map((entry) => ({
		params: { year: String(entry.data.year) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { year, items } = entry.data;

const allEntries = await getCollection('watchlist');
const availableYears = allEntries.map((item) => item.data.year).sort((a, b) => b - a);
const yearIndex = availableYears.indexOf(year);
const previousYear = yearIndex >= 0 ? availableYears[yearIndex + 1] : undefined;
const nextYear = yearIndex > 0 ? availableYears[yearIndex - 1] : undefined;

const isMovieType = (type: WatchlistItem['type']) => type === 'Movie';

const sortedItems: WatchlistItem[] = [...items].sort(
	(a, b) => b.watchedDate.getTime() - a.watchedDate.getTime()
);

const filmItems = sortedItems.filter((item) => isMovieType(item.type));
const tvItems = sortedItems.filter((item) => !isMovieType(item.type));

const filterId = `watchlist-filters-${year}`;
---

<Layout
	title={`${year} Watchlist - Sajib`}
	description={`Watchlist entries from ${year}.`}
	mainClass="watchlist-year-page"
>
	<header class="page-header">
		<p class="page-eyebrow"><a href="/watchlist/">Watchlist</a> / Year</p>
		<h1 class="page-title">
			<em>{year}</em> in<br />review.
		</h1>
		<p class="page-subtitle">
			Everything I watched in {year} - with notes on each.
		</p>
	</header>

	<nav class="year-nav" aria-label="Year navigation">
		{previousYear ? (
			<a href={`/watchlist/${previousYear}/`} class="year-nav-link prev">{previousYear}</a>
		) : (
			<span class="year-nav-link prev" style="opacity:.3; pointer-events:none;">-</span>
		)}
		<span class="year-nav-center">{year}</span>
		{nextYear ? (
			<a href={`/watchlist/${nextYear}/`} class="year-nav-link next">{nextYear}</a>
		) : (
			<span class="year-nav-link next" style="opacity:.3; pointer-events:none;">-</span>
		)}
	</nav>

	<div class="filters" role="tablist" id={filterId}>
		<button class="filter-btn active" data-show="all" type="button">All</button>
		<button class="filter-btn" data-show="film" type="button">Films</button>
		<button class="filter-btn" data-show="tv" type="button">TV Shows</button>
	</div>

	<section class="items-section">
		{filmItems.length ? (
			<div class="items-subsection" data-type="film">
				<p class="section-label">Films</p>
				{filmItems.map((item) => (
					<WatchlistCard item={item} year={year} typeLabel="Film" />
				))}
			</div>
		) : null}

		{tvItems.length ? (
			<div class="items-subsection" data-type="tv">
				<p class="section-label">TV Shows</p>
				{tvItems.map((item) => (
					<WatchlistCard item={item} year={year} typeLabel={item.type} />
				))}
			</div>
		) : null}
	</section>

	<script define:vars={{ filterId }}>
		// @ts-nocheck
		let currentAudioElement = null;

		const stopAudio = () => {
			if (!currentAudioElement) return;
			currentAudioElement.pause();
			currentAudioElement.currentTime = 0;
			currentAudioElement = null;
		};

		const playAudio = (audioElement) => {
			if (!audioElement) return;
			if (currentAudioElement && currentAudioElement !== audioElement) {
				stopAudio();
			}
			currentAudioElement = audioElement;
			audioElement.play();
		};

		const filterRoot = document.getElementById(filterId);
		const sections = document.querySelectorAll('.items-subsection');
		if (filterRoot) {
			filterRoot.querySelectorAll('.filter-btn').forEach((button) => {
				button.addEventListener('click', () => {
					filterRoot.querySelectorAll('.filter-btn').forEach((btn) => btn.classList.remove('active'));
					button.classList.add('active');
					const type = button.getAttribute('data-show');

					sections.forEach((section) => {
						if (type === 'all' || section.getAttribute('data-type') === type) {
							section.classList.remove('hidden');
						} else {
							section.classList.add('hidden');
						}
					});
				});
			});
		}

		document.querySelectorAll('.js-watchlist-row').forEach((row) => {
			const title = row.querySelector('.js-watchlist-title');
			const audioElement = row.querySelector('.js-watchlist-audio');
			if (!title || !audioElement) return;

			title.addEventListener('mouseenter', () => playAudio(audioElement));
			title.addEventListener('mouseleave', () => stopAudio());
			title.addEventListener('focus', () => playAudio(audioElement));
			title.addEventListener('blur', () => stopAudio());
			title.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					playAudio(audioElement);
				}
			});
		});
	</script>
</Layout>
