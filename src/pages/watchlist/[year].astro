---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type WatchlistEntry = CollectionEntry<'watchlist'>;
type WatchlistItem = WatchlistEntry['data']['items'][number];

export async function getStaticPaths() {
	const entries = await getCollection('watchlist');
	return entries.map((entry) => ({
		params: { year: String(entry.data.year) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { year, items } = entry.data;

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(
		date
	);

const sortedItems: WatchlistItem[] = [...items].sort(
	(a, b) => b.watchedDate.getTime() - a.watchedDate.getTime()
);
const posterSrc = (poster: WatchlistItem['poster']) =>
	poster?.startsWith('http') ? poster : `/posters/${poster}`;

const starLabel = (rating: WatchlistItem['rating']) => {
	if (!rating && rating !== 0) return '—';
	return `${rating} / 5`;
};

const starString = (rating: WatchlistItem['rating']) => {
	if (!rating && rating !== 0) return '';
	const full = Math.floor(rating);
	const half = rating % 1 >= 0.5;
	const empty = 5 - full - (half ? 1 : 0);
	return `${'★'.repeat(full)}${half ? '½' : ''}${'☆'.repeat(empty)}`;
};
---

<Layout
	title={`Watchlist · ${year}`}
	description={`Watchlist entries from ${year}.`}
	mainClass="watchlist-year-page"
>
	<header class="page-header">
		<p class="page-eyebrow">Year archive</p>
		<h1 class="page-title">
			Watchlist<br /><em>{year}</em>
		</h1>
		<p class="page-subtitle">{sortedItems.length} titles logged in {year}.</p>
	</header>

	<section class="projects-section">
		<p class="section-label">Entries</p>
		<div class="watchlist-entry-list">
			{sortedItems.map((item) => (
				<article class="watchlist-entry-card js-watchlist-row">
					{item.poster ? (
						<img
							class="watchlist-poster"
							src={posterSrc(item.poster)}
							alt={`${item.title} poster`}
							loading="lazy"
						/>
					) : (
						<div class="watchlist-poster watchlist-poster-placeholder" aria-hidden="true"></div>
					)}
					<div class="watchlist-entry-body">
						<div class="watchlist-entry-head">
							<h2 class="watchlist-entry-title js-watchlist-title" tabindex="0">
								{item.title} {item.year ? `(${item.year})` : ''}
							</h2>
							<span class="watchlist-rating" aria-label={starLabel(item.rating)}>
								{item.rating || item.rating === 0 ? starString(item.rating) : '—'}
							</span>
						</div>
						<p class="watchlist-entry-meta">{item.type} - {formatDate(item.watchedDate)}</p>
						{item.episodes ? (
							<p class="watchlist-entry-meta">{item.episodes} EP{item.episodes === 1 ? '' : 's'}</p>
						) : null}
						{item.review ? <p class="watchlist-entry-review">{item.review}</p> : null}
						{item.audio ? <audio class="js-watchlist-audio" src={`/bgm/${item.audio}`}></audio> : null}
					</div>
				</article>
			))}
		</div>
	</section>

	<p class="back-link">
		<a href="/watchlist/">← Back to years</a>
	</p>

	<script>
		// @ts-nocheck
		let currentAudioElement = null;

		const stopAudio = () => {
			if (!currentAudioElement) return;
			currentAudioElement.pause();
			currentAudioElement.currentTime = 0;
			currentAudioElement = null;
		};

		const playAudio = (audioElement) => {
			if (!audioElement) return;
			if (currentAudioElement && currentAudioElement !== audioElement) {
				stopAudio();
			}
			currentAudioElement = audioElement;
			audioElement.play();
		};

		document.querySelectorAll('.js-watchlist-row').forEach((row) => {
			const title = row.querySelector('.js-watchlist-title');
			const audioElement = row.querySelector('.js-watchlist-audio');
			if (!title || !audioElement) return;

			title.addEventListener('mouseenter', () => playAudio(audioElement));
			title.addEventListener('mouseleave', () => stopAudio());
			title.addEventListener('focus', () => playAudio(audioElement));
			title.addEventListener('blur', () => stopAudio());
			title.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					playAudio(audioElement);
				}
			});
		});
	</script>
</Layout>
