---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

type ProjectEntry = CollectionEntry<'projects'> & { date: Date };

const projects: ProjectEntry[] = (await getCollection('projects'))
	.map((project) => ({
		...project,
		date: project.data.pubDate
	}))
	.sort((a, b) => b.date.getTime() - a.date.getTime());

projects.sort((a, b) => {
	const orderA = a.data.order;
	const orderB = b.data.order;

	if (orderA !== undefined && orderB !== undefined) {
		return orderA - orderB;
	}
	if (orderA !== undefined) {
		return -1;
	}
	if (orderB !== undefined) {
		return 1;
	}
	return b.date.getTime() - a.date.getTime();
});

const tagsFor = (project: ProjectEntry): string[] => {
	if (project.data.tags?.length) return project.data.tags;
	if (!project.data.stack) return [];
	return project.data.stack
		.split(',')
		.map((tag: string) => tag.trim())
		.filter(Boolean);
};
---

<Layout title="Projects - Sajib" description="Selected projects and experiments." mainClass="projects-page">
	<header class="page-header">
		<p class="page-eyebrow">Selected work</p>
		<h1 class="page-title">
			Things I've<br /><em>built.</em>
		</h1>
		<p class="page-subtitle">
			A collection of projects I've worked on - web experiments, tools, and things I found
			interesting enough to ship.
		</p>
	</header>

	<section class="projects-section">
		<p class="section-label">Projects</p>
		<div class="project-list">
			{projects.map((project, index) => (
				<a href={`/projects/${project.slug}/`} class="project-card">
					<span class="project-num">{String(index + 1).padStart(2, '0')}</span>
					<div class="project-body">
						<h2 class="project-title">{project.data.title}</h2>
						<p class="project-desc">{project.data.summary ?? project.data.description ?? 'No description provided yet.'}</p>
						{tagsFor(project).length ? (
							<div class="project-tags">
								{tagsFor(project).map((tag: string) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						) : null}
					</div>
					<span class="project-arrow">→</span>
				</a>
			))}
		</div>
	</section>
</Layout>
