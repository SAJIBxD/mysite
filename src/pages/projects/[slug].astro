---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const formattedDate = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric'
}).format(entry.data.pubDate);

const tagLine = entry.data.tags?.length ? ` - ${entry.data.tags.join(' - ')}` : '';
---

<Layout
	title={entry.data.title}
	description={entry.data.description ?? entry.data.title}
	mainClass="project-detail"
>
	<header class="page-header">
		<p class="page-eyebrow">Project</p>
		<h1 class="page-title">{entry.data.title}</h1>
		<p class="page-subtitle">{entry.data.description ?? 'A project write-up from my archive.'}</p>
		<p class="page-subtitle page-subtitle--mono">{formattedDate}{tagLine}</p>
	</header>

	<article class="prose">
		<Content />
	</article>

	<p class="back-link">
		<a href="/projects/">← Back to projects</a>
	</p>
</Layout>
