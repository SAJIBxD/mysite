---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const formattedDate = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric'
}).format(entry.data.pubDate);

const tagLine = entry.data.tags?.length ? ` · ${entry.data.tags.join(' · ')}` : '';
---

<Layout
	title={entry.data.title}
	description={entry.data.description ?? entry.data.title}
	mainClass="flex-1 max-w-2xl mx-auto w-full page"
>
	<h1 class="text-2xl mb-2">{entry.data.title}</h1>
	<p class="text-sm text-[#666] mb-10">{formattedDate}{tagLine}</p>
	<Content />
	<p class="text-sm">
		<a href="/projects/">← back to projects</a>
	</p>
</Layout>
